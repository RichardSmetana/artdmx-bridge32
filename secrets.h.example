// Copy this file to secrets.h and fill in your credentials.
// secrets.h is listed in .gitignore and must not be committed.
// These values are used as first-boot defaults; the web UI can override them in NVS.

#define SECRETS_WIFI_SSID     "your-wifi-ssid"
#define SECRETS_WIFI_PASS     "your-wifi-password"

// Leave empty ("") to disable OTA password protection (not recommended).
#define SECRETS_OTA_PASSWORD  "your-ota-password"
